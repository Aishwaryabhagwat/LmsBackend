@Service
public class UserVideoProgressServiceImpl implements IUserVideoProgressService {

    @Autowired
    private IUserVideoProgressRepo userVideoProgressRepo;

    @Autowired
    private IUserRepository userRepo;

    @Autowired
    private IVideoRepo videoRepo;
    @Autowired
    private IChapterRepo chapterRepo;

    @Override
    public UserVideoProgress recordProgress(Long userId, Long videoId, int progress) {
        User user = userRepo.findById(userId).orElseThrow(() -> new EntityNotFoundException("User not found"));
        Video video = videoRepo.findById(videoId).orElseThrow(() -> new EntityNotFoundException("Video not found"));

        Optional<UserVideoProgress> existingProgressOpt = userVideoProgressRepo.findByUserIdAndVideoId(userId, videoId);
        UserVideoProgress userVideoProgress;

        if (existingProgressOpt.isPresent()) {
            userVideoProgress = existingProgressOpt.get();
            userVideoProgress.setCompletedDuration(progress);;
        } else {
            userVideoProgress = new UserVideoProgress();
            userVideoProgress.setUser(user);
            userVideoProgress.setVideo(video);
            userVideoProgress.setCompletedDuration(progress);
        }

        return userVideoProgressRepo.save(userVideoProgress); 
    }

