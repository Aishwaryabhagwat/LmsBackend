    @Override
    public double calculateCourseProgress(Long userId, Long courseId) {
        List<UserVideoProgress> progressList = getProgressByUserIdAndCourseId(userId, courseId);
        double totalDuration = progressList.stream().mapToInt(p -> p.getVideo().getDuration()).sum();
        double completedDuration = progressList.stream().mapToInt(UserVideoProgress::getCompletedDuration).sum();

        double progressPercentage = (completedDuration / totalDuration) * 100;
        return Math.round(progressPercentage);
    }
