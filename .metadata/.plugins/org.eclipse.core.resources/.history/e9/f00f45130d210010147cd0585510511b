    @PostMapping("/create")
    public ResponseEntity<APIResponse<String>> createCourse(
            @RequestParam("name") String name,
            @RequestParam("description") String description,
            @RequestParam("author") String author,
            @RequestParam("categoryId") Long categoryId,
            @RequestParam("imageFile") MultipartFile imageFile) throws IOException {
        
        Course createdCourse = courseService.createCourse(name, description, author, categoryId, imageFile);
        String message = "course '" + createdCourse.getName() + "' created successfully with ID: " + createdCourse.getId();
        return ResponseEntity.ok(new APIResponse<>("success", message, "course created successfully"));
    }

    @PutMapping("/update/{id}")
    public ResponseEntity<APIResponse<String>> updateCourse(
            @PathVariable Long id,
            @RequestParam("name") String name,
            @RequestParam("description") String description,
            @RequestParam("author") String author,
            @RequestParam("categoryId") Long categoryId,
            @RequestParam("imageFile") MultipartFile imageFile) {

        Course updatedCourse = courseService.updateCourse(id, name, description, author, categoryId, imageFile);
        String message = "Course with ID: " + updatedCourse.getId() + " updated successfully to '" + updatedCourse.getName() + "'";
        return ResponseEntity.ok(new APIResponse<>("success", message, "Course updated successfully"));
    }

    @PutMapping("/delete/{id}")
    public ResponseEntity<APIResponse<String>> deleteCourse(@PathVariable Long id) {
        courseService.deleteCourse(id);
        return ResponseEntity.ok(new APIResponse<>("success", "Course deleted successfully", ""));
    }
}
