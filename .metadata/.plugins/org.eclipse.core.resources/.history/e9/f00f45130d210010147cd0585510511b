package com.cdac.E_Learning.controller;

import java.io.IOException;
import java.util.Collection;
import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;
import org.springframework.web.multipart.MultipartFile;

import com.cdac.E_Learning.dto.APIResponse;
import com.cdac.E_Learning.dto.EnrollRequestDTO;
import com.cdac.E_Learning.dto.EnrollmentRequestDTO;
import com.cdac.E_Learning.pojo.Category;
import com.cdac.E_Learning.pojo.Course;
import com.cdac.E_Learning.repo.CategoryRepository;
import com.cdac.E_Learning.service.ICourseService;

@RestController
@RequestMapping("/api/course")
public class CourseController {

    @Autowired
    private ICourseService courseService;
    
    @Autowired
    private CategoryRepository categoryRepository;
    
    
    @GetMapping("/pending-enrollments")
    public ResponseEntity<List<EnrollRequestDTO>> getPendingRequests() {
        return ResponseEntity.ok(courseService.getPendingRequests());
    }

    @PostMapping("/approve-enrollment")
    public ResponseEntity<Map<String, String>> approveRequest(@RequestParam Long requestId) {
        courseService.approveEnrollmentRequest(requestId);
        return ResponseEntity.ok(Collections.singletonMap("message", "Enrollment request approved"));
    }

    @PostMapping("/reject-enrollment")
    public ResponseEntity<Map<String, String>> rejectRequest(@RequestParam Long requestId) {
        courseService.rejectEnrollmentRequest(requestId);
        return ResponseEntity.ok(Collection.singletonMap("message", "Enrollment request rejected"));
    }

    
    

    @GetMapping("/getAllCourses")
    public APIResponse<List<Course>> getAllCourses() {
        List<Course> course = courseService.getAllCourses();
        if (!course.isEmpty()) {
            return new APIResponse<>("success", course, "no error");
        } else {
            return new APIResponse<>("error", null, "No course found");
        }
    }
    
    @GetMapping("/{courseId}/image")
    public ResponseEntity<APIResponse<String>> getCourseImageUrl(@PathVariable Long courseId) {
        String imageUrl = courseService.getCourseImageUrl(courseId);
        if (imageUrl != null) {
            return ResponseEntity.ok(new APIResponse<>("success", imageUrl, "No error"));
        } else {
            return ResponseEntity.ok(new APIResponse<>("error", null, "Image not found for courseId: " + courseId));
        }
    }


    @GetMapping("/getCourseById/{id}")
    public ResponseEntity<APIResponse<Course>> getCourseById(@PathVariable Long id) {
        Course course = courseService.getCourseById(id);
        if (course != null) {
            return ResponseEntity.ok(new APIResponse<>("success", course, "Course fetched successfully"));
        } else {
            return ResponseEntity.status(404).body(new APIResponse<>("error", null, "Course not found"));
        }
    }

