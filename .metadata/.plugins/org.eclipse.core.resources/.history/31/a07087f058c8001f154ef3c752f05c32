	   public void addQuestion(Long quizId, QuestionDTO questionDTO) {
	        // Fetch the quiz by its ID
	        Quiz quiz = quizRepository.findById(quizId)
	                .orElseThrow(() -> new ResourceNotFoundException("Quiz not found with id: " + quizId));

	        // Create a new Question entity
	        Question question = new Question();
	        question.setContent(questionDTO.getContent());
	        question.setCorrectOptionIndex(questionDTO.getCorrectOptionIndex());
	        question.setIsActive(1); // Set status to active (assuming 1 is active)

	        // Set the relation with the quiz
	        question.setQuiz(quiz);

	        // Save the question first to get the generated ID
	        questionRepository.save(question);

	        // Map options
	        List<QuizOption> options = questionDTO.getOptions().stream().map(optionText -> {
	            QuizOption option = new QuizOption();
	            option.setText(optionText);
	            option.setQuestion(question); // Set the question reference here
	            return option;
	        }).collect(Collectors.toList());

	        // Save the options
	  
	        quizOptionRepository.saveAll(options);  /// Save all options associated with the question
	    }
	   
	   
	   
	   public void updateQuestion(Long questionId, QuestionDTO questionDTO) {
		    // Fetch the question by its ID
		    Question question = questionRepository.findById(questionId)
		            .orElseThrow(() -> new ResourceNotFoundException("Question not found with id: " + questionId));

		    // Update question content and correct option index
		    question.setContent(questionDTO.getContent());
		    question.setCorrectOptionIndex(questionDTO.getCorrectOptionIndex());
		    
		    // Update the options
		    List<QuizOption> options = quizOptionRepository.findByQuestionId(questionId);

		    // Ensure options length matches the input
		    if (options.size() != questionDTO.getOptions().size()) {
		        throw new IllegalArgumentException("The number of options provided does not match existing options.");
		    }

		    // Update each option's text
		    for (int i = 0; i < options.size(); i++) {
		        options.get(i).setText(questionDTO.getOptions().get(i));
		    }

		    // Save the updated question and options
		    questionRepository.save(question);
		    quizOptionRepository.saveAll(options);
		}

	   
	   public QuestionDTO getQuestionById(Long questionId) {
	        Question question = questionRepository.findById(questionId)
	            .orElseThrow(() -> new ResourceNotFoundException("Question not found with id: " + questionId));

	        // Fetch the related options
	        List<QuizOption> options = quizOptionRepository.findByQuestionId(questionId);

	        // Map the data to QuestionDTO
	        QuestionDTO questionDTO = new QuestionDTO();
	       
	        questionDTO.setContent(question.getContent());
	        questionDTO.setCorrectOptionIndex(question.getCorrectOptionIndex());

	        List<String> optionTexts = options.stream()
	            .map(QuizOption::getText)
	            .collect(Collectors.toList());
	        questionDTO.setOptions(optionTexts);

	        return questionDTO;
	    }
	   
