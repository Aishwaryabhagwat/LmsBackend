	    public UserQuizResult calculateResult(QuizSubmissionRequest submissionRequest) {
	        User user = userRepository.findById(submissionRequest.getUser().getId())
	                .orElseThrow(() -> new ResourceNotFoundException("User not found with id: " + submissionRequest.getUser().getId()));
	        
	        Quiz quiz = quizRepository.findById(submissionRequest.getQuizId())
	                .orElseThrow(() -> new ResourceNotFoundException("Quiz not found with id: " + submissionRequest.getQuizId()));

	        int totalQuestions = submissionRequest.getUserAnswers().size();
	        int correctAnswers = 0;

	        for (UserAnswer userAnswer : submissionRequest.getUserAnswers()) {
	            Question question = questionRepository.findById(userAnswer.getQuestion().getId())
	                    .orElseThrow(() -> new ResourceNotFoundException("Question not found with id: " + userAnswer.getQuestion().getId()));

	            // Check if the selected option is correct
	            if (userAnswer.getSelectedOptionIndex() == question.getCorrectOptionIndex()) {
	                correctAnswers++;
	            }
	        }

	        int score = (int) ((correctAnswers / (double) totalQuestions) * 100); // Calculate score as a percentage

	        UserQuizResult quizResult = new UserQuizResult();
	        quizResult.setUser(user);
	        quizResult.setQuiz(quiz);
	        quizResult.setTotalQuestions(totalQuestions);
	        quizResult.setCorrectAnswers(correctAnswers);
	        quizResult.setScore(score);
	        quizResult.setCompleted(true);

	        return userQuizResultRepository.save(quizResult);
	    }
	   
	    
